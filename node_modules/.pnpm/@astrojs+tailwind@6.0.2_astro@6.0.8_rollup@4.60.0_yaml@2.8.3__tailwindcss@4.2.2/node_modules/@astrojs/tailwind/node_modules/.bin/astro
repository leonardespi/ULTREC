if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/lenny/git/ULTREC/node_modules/.pnpm/astro@6.0.8_rollup@4.60.0_yaml@2.8.3/node_modules/astro/bin/node_modules:/home/lenny/git/ULTREC/node_modules/.pnpm/astro@6.0.8_rollup@4.60.0_yaml@2.8.3/node_modules/astro/node_modules:/home/lenny/git/ULTREC/node_modules/.pnpm/astro@6.0.8_rollup@4.60.0_yaml@2.8.3/node_modules:/home/lenny/git/ULTREC/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/lenny/git/ULTREC/node_modules/.pnpm/astro@6.0.8_rollup@4.60.0_yaml@2.8.3/node_modules/astro/bin/node_modules:/home/lenny/git/ULTREC/node_modules/.pnpm/astro@6.0.8_rollup@4.60.0_yaml@2.8.3/node_modules/astro/node_modules:/home/lenny/git/ULTREC/node_modules/.pnpm/astro@6.0.8_rollup@4.60.0_yaml@2.8.3/node_modules:/home/lenny/git/ULTREC/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../../astro@6.0.8_rollup@4.60.0_yaml@2.8.3/node_modules/astro/bin/astro.mjs" "$@"
else
  exec node  "$basedir/../../../../../../astro@6.0.8_rollup@4.60.0_yaml@2.8.3/node_modules/astro/bin/astro.mjs" "$@"
fi
