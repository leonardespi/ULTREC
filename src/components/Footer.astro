---
import { SITE } from '../config/site';
const base = import.meta.env.BASE_URL;

const navLinks = [
  { href: `${base}/`,                 label: 'Inicio' },
  { href: `${base}/dispositivos`,     label: 'Dispositivos' },
  { href: `${base}/servicios`,        label: 'Servicios' },
  { href: `${base}/servicio-cliente`, label: 'Servicio al Cliente' },
  { href: `${base}/contacto`,         label: 'Contacto' },
];
---

<footer>
  <div class="footer-grid">
    <!-- Col 1: Brand -->
    <div class="footer-col">
      <a href={`${base}/`} aria-label="ULTREC — Inicio">
        <img
          src={`${base}/imgs/logo-ultrec.png`}
          alt="ULTREC"
          width="120"
          height="48"
          class="footer-logo"
        />
      </a>
      <p class="tagline">{SITE.tagline}</p>
    </div>

    <!-- Col 2: Nav -->
    <div class="footer-col">
      <h3 class="footer-heading">Navegación</h3>
      <ul role="list" class="footer-list">
        {navLinks.map(link => (
          <li><a href={link.href} class="footer-link">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Col 3: Contacto -->
    <div class="footer-col">
      <h3 class="footer-heading">Contacto</h3>
      <ul role="list" class="footer-list contact-list">
        <li>
          <span class="contact-label">Ventas:</span>
          <a href={`mailto:${SITE.contact.emailSales}`} class="footer-link">{SITE.contact.emailSales}</a>
        </li>
        <li>
          <span class="contact-label">Servicios:</span>
          <a href={`mailto:${SITE.contact.emailService}`} class="footer-link">{SITE.contact.emailService}</a>
        </li>
        <li>
          <span class="contact-label">Tel. ventas:</span>
          <a href={`tel:${SITE.contact.phoneSales.replace(/\s/g,'')}`} class="footer-link">{SITE.contact.phoneSales}</a>
        </li>
        <li>
          <span class="contact-label">Tel. servicio:</span>
          <a href={`tel:${SITE.contact.phoneService1.replace(/\s/g,'')}`} class="footer-link">{SITE.contact.phoneService1}</a>
          {' / '}
          <a href={`tel:${SITE.contact.phoneService2.replace(/\s/g,'')}`} class="footer-link">{SITE.contact.phoneService2}</a>
        </li>
        <li>
          <span class="contact-label">Dirección:</span>
          <span class="footer-text">{SITE.contact.address}</span>
        </li>
        <li>
          <span class="contact-label">Horario:</span>
          <span class="footer-text">{SITE.contact.hours}</span>
        </li>
      </ul>
    </div>

    <!-- Col 4: Redes Sociales -->
    <div class="footer-col">
      <h3 class="footer-heading">Redes Sociales</h3>
      <ul role="list" class="footer-list social-list">
        <li>
          <a
            href={SITE.social.tiktok}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label="ULTREC en TikTok"
          >
            <!-- TikTok icon -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.87a8.18 8.18 0 0 0 4.78 1.52V6.94a4.86 4.86 0 0 1-1.01-.25z"/>
            </svg>
            TikTok
          </a>
        </li>
        <li>
          <a
            href={SITE.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label="ULTREC en Instagram"
          >
            <!-- Instagram icon -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
            Instagram
          </a>
        </li>
        <li>
          <a
            href={SITE.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label="ULTREC en Facebook"
          >
            <!-- Facebook icon -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
            Facebook
          </a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <span>© 2024 ULTREC. Todos los derechos reservados.</span>
    <a href={`${base}/privacidad`} class="privacy-link">Aviso de Privacidad</a>
  </div>
</footer>

<style>
  footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 48px 24px 0;
    font-family: var(--font-body);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
    max-width: 1280px;
    margin: 0 auto;
  }
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .footer-logo {
    height: 40px;
    width: auto;
    margin-bottom: 12px;
  }
  .tagline {
    color: var(--color-text-muted);
    font-size: 13px;
    line-height: 1.6;
    margin-top: 8px;
  }
  .footer-heading {
    color: var(--color-cyan);
    font-family: var(--font-display);
    font-size: 18px;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }
  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s;
  }
  .footer-link:hover {
    color: var(--color-cyan);
  }
  .contact-list li {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 13px;
  }
  .contact-label {
    color: var(--color-text);
    font-weight: 600;
    white-space: nowrap;
  }
  .footer-text {
    color: var(--color-text-muted);
  }
  .social-list {
    gap: 14px;
  }
  .social-link {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s;
  }
  .social-link:hover {
    color: var(--color-cyan);
  }
  .footer-bottom {
    max-width: 1280px;
    margin: 0 auto;
    border-top: 1px solid var(--color-border);
    margin-top: 40px;
    padding: 20px 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    color: var(--color-text-muted);
  }
  .privacy-link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .privacy-link:hover {
    color: var(--color-cyan);
  }
</style>
