---
import { carouselSlides } from '../data/content';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!-- Swiper carousel -->
<div class="swiper product-swiper">
  <div class="swiper-wrapper">
    {carouselSlides.map((slide) => (
      <div class="swiper-slide">
        <div class="slide-card card-glow">
          <img src={`${base}/imgs/${slide.image}`} alt={slide.name} class="slide-img" loading="lazy" />
          <div class="slide-body">
            <h3 class="slide-name">{slide.name}</h3>
            <p class="slide-desc">{slide.description}</p>
            <a href={`${base}/dispositivos`} class="slide-cta">Ver más →</a>
          </div>
        </div>
      </div>
    ))}
  </div>
  <div class="swiper-pagination"></div>
  <button class="swiper-button-prev" aria-label="Producto anterior"></button>
  <button class="swiper-button-next" aria-label="Siguiente producto"></button>
</div>

<style>
  .product-swiper {
    width: 100%;
    padding-bottom: 48px !important;
    padding-top: 8px;
  }
  .slide-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .slide-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    background: var(--color-surface-alt);
  }
  .slide-img-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 13px;
    font-family: var(--font-body);
  }
  .slide-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  .slide-name {
    color: var(--color-text);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    line-height: 1.4;
    margin: 0;
  }
  .slide-desc {
    color: var(--color-text-muted);
    font-size: 13px;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }
  .slide-cta {
    color: var(--color-cyan);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    margin-top: 8px;
    transition: color 0.2s;
    align-self: flex-start;
  }
  .slide-cta:hover {
    color: var(--color-glow);
  }
  /* Equal-height slides */
  :global(.product-swiper .swiper-wrapper) {
    align-items: stretch;
  }
  :global(.product-swiper .swiper-slide) {
    display: flex;
    height: auto;
  }

  /* Swiper overrides */
  :global(.swiper-button-prev),
  :global(.swiper-button-next) {
    color: var(--color-cyan) !important;
  }
  :global(.swiper-pagination-bullet) {
    background: var(--color-text-muted) !important;
    opacity: 0.5;
  }
  :global(.swiper-pagination-bullet-active) {
    background: var(--color-cyan) !important;
    opacity: 1;
  }
</style>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/navigation';
  import 'swiper/css/pagination';

  new Swiper('.product-swiper', {
    modules: [Navigation, Pagination, Autoplay],
    slidesPerView: 1,
    spaceBetween: 24,
    loop: true,
    autoplay: {
      delay: 5000,
      disableOnInteraction: false,
    },
    navigation: {
      prevEl: '.swiper-button-prev',
      nextEl: '.swiper-button-next',
    },
    pagination: {
      el: '.swiper-pagination',
      clickable: true,
    },
    breakpoints: {
      640:  { slidesPerView: 2 },
      1024: { slidesPerView: 3 },
    },
  });
</script>
