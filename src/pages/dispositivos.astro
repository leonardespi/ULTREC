---
import Layout from '../layouts/Layout.astro';
import { dispositivosCategories, identificationItems } from '../data/content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const contactoUrl = `${base}/contacto?asunto=Cotizaci%C3%B3n`;

// Alternate background on even-indexed categories
const altIds = new Set(
  dispositivosCategories
    .filter((_, i) => i % 2 !== 0)
    .map(c => c.id)
);
---

<Layout
  title="Dispositivos"
  description="Catálogo completo de torniquetes de cuerpo completo, sistemas de control de acceso y máquinas vending ULTREC."
>
  <div class="page-wrapper">
    <!-- Page header -->
    <section class="page-header">
      <div class="container">
        <h1 class="page-title">Dispositivos</h1>
        <p class="page-desc">
          Soluciones de fabricación propia para el control de acceso y retail autónomo. Cada equipo está diseñado
          para entornos de alto tráfico con los más altos estándares de calidad.
        </p>
      </div>
    </section>

    <!-- Product categories — driven by src/data/content.yml -->
    {dispositivosCategories.map((cat) => (
      <section
        class={`category-section${altIds.has(cat.id) ? ' alt-bg' : ''}`}
        aria-labelledby={`${cat.id}-heading`}
      >
        <div class="container">
          <h2 id={`${cat.id}-heading`} class="category-heading">
            <span class="category-line"></span>
            {cat.title}
          </h2>
          <div class="product-grid">
            {cat.products.map(p => (
              <article class="product-card card-glow">
                <img
                  src={`${base}/imgs/${p.image}`}
                  alt={p.name}
                  class="product-img"
                  loading="lazy"
                />
                <div class="product-body">
                  <h3 class="product-name">{p.name}</h3>
                  <p class="product-desc">{p.description}</p>
                  {p.variants && p.variants.length > 0 && (
                    <div class="variant-badges" aria-label="Modelos disponibles">
                      {p.variants.map(v => <span class="badge">{v}</span>)}
                    </div>
                  )}
                  <a href={contactoUrl} class="product-cta">Solicitar Info →</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))}

    <!-- Identification methods — driven by src/data/content.yml -->
    <section class="id-section alt-bg" aria-labelledby="id-heading">
      <div class="container">
        <h2 id="id-heading" class="category-heading">
          <span class="category-line"></span>
          Métodos de Identificación Compatibles con Nuestros Sistemas
        </h2>
        <div class="id-grid">
          {identificationItems.map(item => (
            <div class="id-card card-glow">
              <div class="id-icon-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                  <line x1="8" y1="21" x2="16" y2="21"/>
                  <line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
              </div>
              <div>
                <h3 class="id-label">{item.label}</h3>
                <p class="id-desc">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .page-wrapper {
    background: var(--color-bg);
  }
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .page-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 64px 0 48px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(48px, 8vw, 96px);
    color: var(--color-text);
    letter-spacing: 0.05em;
    margin: 0 0 16px;
  }
  .page-desc {
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.8;
    max-width: 700px;
    margin: 0;
  }
  .category-section {
    padding: 72px 0;
    background: var(--color-bg);
  }
  .alt-bg {
    background: var(--color-surface-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .category-heading {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 48px);
    color: var(--color-text);
    letter-spacing: 0.05em;
    margin: 0 0 40px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .category-line {
    display: block;
    width: 4px;
    height: 1em;
    background: var(--color-cyan);
    border-radius: 2px;
    flex-shrink: 0;
  }
  .product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 640px) {
    .product-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .product-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .product-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .product-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    background: var(--color-surface-alt);
  }

  .product-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .product-name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 15px;
    color: var(--color-text);
    margin: 0;
    line-height: 1.4;
  }
  .product-desc {
    color: var(--color-text-muted);
    font-size: 13px;
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }
  .variant-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .badge {
    background: rgba(0, 200, 240, 0.1);
    color: var(--color-cyan);
    border: 1px solid rgba(0, 200, 240, 0.3);
    border-radius: 4px;
    padding: 3px 10px;
    font-size: 12px;
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: 0.03em;
  }
  .product-cta {
    color: var(--color-cyan);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: color 0.2s;
    align-self: flex-start;
    margin-top: auto;
  }
  .product-cta:hover {
    color: var(--color-glow);
  }

  /* Identification */
  .id-section {
    padding: 72px 0;
  }
  .id-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 640px) {
    .id-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .id-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .id-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 20px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }
  .id-icon-wrap {
    color: var(--color-cyan);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .id-label {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    color: var(--color-text);
    margin: 0 0 4px;
  }
  .id-desc {
    color: var(--color-text-muted);
    font-size: 13px;
    margin: 0;
  }
</style>
